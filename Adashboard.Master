                                <a href="/NoticeDashboard.aspx" class="list-group-item list-group-item-action"><i class="bi bi-envelope-fill"></i><span class="sidebar-text"> Notice Board</span></a>
                                <a href="/Poll_Result.aspx" class="list-group-item list-group-item-action"><i class="bi bi-bar-chart-fill"></i><span class="sidebar-text"> Poll</span></a>
                                <a href="/View_Document.aspx" class="list-group-item list-group-item-action"><i class="fas fa-file-alt me-2"></i><span class="sidebar-text">Documents</span></a>
                                <a href="/PhotoGallery.aspx" class="list-group-item list-group-item-action"><i class="bi bi-images me-2"></i><span class="sidebar-text">Photo Gallery</span></a>
                            </div>
